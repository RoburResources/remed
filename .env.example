# Server-side only. Never paste real secrets into chat logs.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=rotate_and_set_service_role_key

OPENAI_API_KEY=replace_with_rotated_openai_api_key
OPENAI_MODEL=gpt-5.5
OPENAI_COST_INPUT_CENTS_PER_1K=1.0
OPENAI_COST_OUTPUT_CENTS_PER_1K=4.0

CRON_SECRET=generate_32_plus_random_chars
DASHBOARD_API_TOKEN=generate_32_plus_random_chars
APPROVAL_SECRET=generate_32_plus_random_chars
PUBLIC_BASE_URL=https://your-vercel-deployment.vercel.app

OWNER_PHONE=+61000000000

TWILIO_ACCOUNT_SID=rotate_and_set
TWILIO_AUTH_TOKEN=rotate_and_set
TWILIO_PHONE_NUMBER=+61xxxxxxxxx

RETELL_API_KEY=key_rotate_and_set
RETELL_AGENT_ID=age_or_agent_rotate_and_set
RETELL_FROM_NUMBER=+61xxxxxxxxx

# Optional: Make.com webhook for sending compliance-approved email.
MAKE_EMAIL_WEBHOOK_URL=https://hook.make.com/...
MAKE_WEBHOOK_SECRET=generate_32_plus_random_chars_for_make_callbacks
FROM_EMAIL=ops@example.com
REPLY_TO_EMAIL=owner@example.com

# Staging smoke test only. Never point this at production.
STAGING_BASE_URL=https://your-staging-deployment.vercel.app
STAGING_CONFIRM_NON_PRODUCTION=true
